{
  "expo": {
    "name": "Plate Blur Mobile",
    "slug": "plate-blur-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plateblurmobile",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plateblur.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.plateblur.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "onnxruntime-react-native",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Plate Blur to take photos so it can detect and blur license plates on-device.",
          "photosPermission": "Allow Plate Blur to import photos so it can detect and blur license plates."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Plate Blur to access photos so it can open and save redacted images.",
          "savePhotosPermission": "Allow Plate Blur to save edited photos back to your library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
